# 通用本地样例。
# 当前项目已拆分四套模式：.env.development / .env.test / .env.staging / .env.production。
# 本文件保留为兜底参考；日常请优先改对应模式文件。

# 前端开发服务监听地址
FRONTEND_HOST=127.0.0.1

# 前端开发服务端口（pnpm dev）
FRONTEND_PORT=5173

# 前端预览服务端口（pnpm preview）
FRONTEND_PREVIEW_PORT=4173

# 同域 API 入口。开发环境配合 Vite 代理转发到后端。
VITE_API_BASE_URL=/api/v1

# 仅用于 Vite dev / preview 的反向代理目标，填写后端源站 origin，不要带 /api/v1。
VITE_API_PROXY_TARGET=http://127.0.0.1:5485

# Electron Forge GitHub 发布配置（可选）
# 仅当执行 pnpm electron:publish 且需要自动发布到 GitHub Release 时填写
ELECTRON_GITHUB_OWNER=
ELECTRON_GITHUB_REPO=

# GitHub 访问令牌（需具备 repo 权限）
GITHUB_TOKEN=

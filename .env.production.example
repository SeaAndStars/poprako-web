# 前端生产构建环境样例。
# lpn.seastarss.cn 是前端站点，前后端一起部署时直接走同域 /api/v1。

VITE_API_BASE_URL=/api/v1

# 仅用于本地 preview 生产产物时调试后端；线上静态部署不会用到它。
VITE_API_PROXY_TARGET=http://127.0.0.1:5485

FRONTEND_PREVIEW_PORT=4173

# Windows 桌面客户端自动更新（Squirrel / 对象存储）
# 指向包含 RELEASES 与 *.nupkg 的目录，例如 https://cdn.example.com/poprako/stable/win32/x64
POPRAKO_DESKTOP_UPDATE_BASE_URL=

# 用于构建下一版 delta 包；通常与 UPDATE_BASE_URL 相同
POPRAKO_DESKTOP_REMOTE_RELEASES_URL=

# 是否在打包后的桌面端自动检查更新
POPRAKO_DESKTOP_AUTO_UPDATE=false

# 自动检查更新间隔（分钟，最小按 5 分钟处理）
POPRAKO_DESKTOP_UPDATE_INTERVAL_MINUTES=60

# Electron 远程渲染入口（设置后，打包桌面端优先加载该线上站点）
POPRAKO_RENDERER_REMOTE_URL=https://lpn.seastarss.cn